# LOCAL DEVELOPMENT template (XAMPP). For deployed environments use:
#   Production: deploy/env/backend.env.production.example  (api.klicklocal.app, main)
#   Staging:    deploy/env/backend.env.staging.example     (api-test.klicklocal.app, develop)
APP_NAME="Klicklocal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:1981/klicklocal/backend/public

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=klicklocal
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Social providers: fake (default) or api (real integrations)
SOCIAL_FACEBOOK_DRIVER=fake
SOCIAL_INSTAGRAM_DRIVER=fake
SOCIAL_LINKEDIN_DRIVER=fake

# Instagram Business Login (https://developers.facebook.com/docs/instagram-platform/instagram-api-with-instagram-login/business-login)
INSTAGRAM_ENABLED=false
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI="${APP_URL}/api/v1/social-accounts/instagram/callback"
INSTAGRAM_FRONTEND_REDIRECT="${FRONTEND_URL}/social-accounts"
INSTAGRAM_MEDIA_PUBLIC_BASE_URL="${APP_URL}/storage"
FRONTEND_URL=http://localhost:3000

# TikTok Login Kit / Content Posting (https://developers.tiktok.com/)
TIKTOK_ENABLED=false
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI="${APP_URL}/api/v1/social-accounts/tiktok/callback"
TIKTOK_FRONTEND_REDIRECT="${FRONTEND_URL}/social-accounts"
SOCIAL_FAKE_SUCCESS_RATE=0.85
SOCIAL_FAKE_MIN_DELAY_MS=1000
SOCIAL_FAKE_MAX_DELAY_MS=2000

# RevenueCat mobile in-app purchases (https://www.revenuecat.com/docs/integrations/webhooks)
# Must match the Authorization header value configured in the RevenueCat dashboard.
REVENUECAT_WEBHOOK_AUTH_TOKEN=test_CltWHfYVsKoxkWhrQjAplQPDYGy

# AI content generation (OpenAI GPT-5)
# Leave OPENAI_API_KEY empty to use the deterministic local fake driver.
OPENAI_DRIVER=fake
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=60

CACHE_STORE=database

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:1981,127.0.0.1,127.0.0.1:1981

L5_SWAGGER_CONST_HOST=http://localhost:1981/klicklocal/backend/public/api/v1
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_UI_PERSIST_AUTHORIZATION=true

MAIL_MAILER=log
