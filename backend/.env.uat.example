# UAT — copy to .env.uat and fill secrets (do not commit .env.uat)
# cp .env.uat.example .env.uat

APP_NAME="Klicklocal"
APP_ENV=uat
APP_KEY=
APP_DEBUG=false
# Full URL to the Laravel public folder (no trailing slash)
# gastrocycle.com with doc root = public:
APP_URL=https://gastrocycle.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# IONOS / webspace-host MySQL 8.0
DB_CONNECTION=mysql
DB_HOST=database-5020578088.webspace-host.com
DB_PORT=3306
DB_DATABASE=dbs15734238
DB_USERNAME=dbu1020849
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Comma-separated: your UAT frontend origin(s) for Sanctum cookie auth
SANCTUM_STATEFUL_DOMAINS=gastrocycle.com,www.gastrocycle.com,localhost:3000

CORS_ALLOWED_ORIGINS=https://gastrocycle.com,https://www.gastrocycle.com,http://localhost:3000

SOCIAL_FACEBOOK_DRIVER=fake
SOCIAL_INSTAGRAM_DRIVER=api
SOCIAL_LINKEDIN_DRIVER=fake

INSTAGRAM_ENABLED=true
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=https://gastrocycle.com/public/api/v1/social-accounts/instagram/callback
INSTAGRAM_FRONTEND_REDIRECT=https://klicklocal.vercel.app/social-accounts
INSTAGRAM_MEDIA_PUBLIC_BASE_URL=https://gastrocycle.com/public/storage
FRONTEND_URL=https://klicklocal.vercel.app
SOCIAL_FAKE_SUCCESS_RATE=0.85
SOCIAL_FAKE_MIN_DELAY_MS=1000
SOCIAL_FAKE_MAX_DELAY_MS=2000

L5_SWAGGER_CONST_HOST=https://gastrocycle.com/api/v1
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_UI_PERSIST_AUTHORIZATION=true

MAIL_MAILER=log

# Optional overrides for db:seed admin user
# PLATFORM_ADMIN_EMAIL=admin@klicklocal.test
# PLATFORM_ADMIN_PASSWORD=password
