# Klicklocal backend — STAGING template (formerly "UAT")
# Domain: https://api-test.klicklocal.app   (deploys from `develop` branch)
# Copy to .env.staging (or backend/.env on the staging box) and fill secrets:
#   cp .env.uat.example .env.staging
#
# The canonical server template lives at deploy/env/backend.env.staging.example.
# RULES: no localhost in deployed envs; all endpoints via env vars; staging DB
#        isolated from production.

APP_NAME="Klicklocal (Staging)"
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://api-test.klicklocal.app

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_DE

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# Staging database — isolated, never shared with production.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=klicklocal_staging
DB_USERNAME=klicklocal_staging
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

SANCTUM_STATEFUL_DOMAINS=test.klicklocal.app,admin-test.klicklocal.app
CORS_ALLOWED_ORIGINS=https://test.klicklocal.app,https://admin-test.klicklocal.app

SOCIAL_FACEBOOK_DRIVER=fake
SOCIAL_INSTAGRAM_DRIVER=api
SOCIAL_LINKEDIN_DRIVER=fake

INSTAGRAM_ENABLED=true
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=https://api-test.klicklocal.app/api/v1/social-accounts/instagram/callback
INSTAGRAM_FRONTEND_REDIRECT=https://test.klicklocal.app/social-accounts
INSTAGRAM_MEDIA_PUBLIC_BASE_URL=https://api-test.klicklocal.app/storage
FRONTEND_URL=https://test.klicklocal.app
SOCIAL_FAKE_SUCCESS_RATE=0.85
SOCIAL_FAKE_MIN_DELAY_MS=1000
SOCIAL_FAKE_MAX_DELAY_MS=2000

L5_SWAGGER_CONST_HOST=https://api-test.klicklocal.app/api/v1
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_UI_PERSIST_AUTHORIZATION=true

MAIL_MAILER=log

# Optional overrides for db:seed admin user
# PLATFORM_ADMIN_EMAIL=admin@klicklocal.app
# PLATFORM_ADMIN_PASSWORD=CHANGE_ME
