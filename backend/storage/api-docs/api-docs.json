{
    "openapi": "3.0.0",
    "info": {
        "title": "Klicklocal Scheduler API",
        "description": "Social media scheduling SaaS API. Authenticate with Bearer token (Laravel Sanctum).",
        "version": "1.0.0"
    },
    "paths": {
        "/auth/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Register a new user",
                "operationId": "authRegister",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Registered"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            }
        },
        "/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login and receive bearer token",
                "operationId": "authLogin",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Logged in"
                    },
                    "422": {
                        "description": "Invalid credentials"
                    }
                },
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            }
        },
        "/auth/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Revoke current token",
                "operationId": "authLogout",
                "responses": {
                    "200": {
                        "description": "Logged out"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            }
        },
        "/auth/me": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Get authenticated user",
                "operationId": "authMe",
                "responses": {
                    "200": {
                        "description": "Current user"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            }
        },
        "/workspaces": {
            "get": {
                "tags": [
                    "Workspaces"
                ],
                "summary": "List workspaces for current user",
                "operationId": "workspacesIndex",
                "responses": {
                    "200": {
                        "description": "Workspace list"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            },
            "post": {
                "tags": [
                    "Workspaces"
                ],
                "summary": "Create workspace",
                "operationId": "workspacesStore",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "timezone": {
                                        "type": "string"
                                    },
                                    "logo": {
                                        "type": "string",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Created"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            }
        },
        "/workspaces/{workspace}": {
            "get": {
                "tags": [
                    "Workspaces"
                ],
                "summary": "Get workspace",
                "operationId": "workspacesShow",
                "parameters": [
                    {
                        "name": "workspace",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Workspace details"
                    },
                    "403": {
                        "description": "Forbidden"
                    },
                    "404": {
                        "description": "Not found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            },
            "put": {
                "tags": [
                    "Workspaces"
                ],
                "summary": "Update workspace",
                "operationId": "workspacesUpdate",
                "parameters": [
                    {
                        "name": "workspace",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "timezone": {
                                        "type": "string"
                                    },
                                    "logo": {
                                        "type": "string",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Updated"
                    },
                    "403": {
                        "description": "Forbidden"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Workspaces"
                ],
                "summary": "Delete workspace",
                "operationId": "workspacesDestroy",
                "parameters": [
                    {
                        "name": "workspace",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Deleted"
                    },
                    "403": {
                        "description": "Forbidden"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            }
        },
        "/posts": {
            "get": {
                "tags": [
                    "Posts"
                ],
                "summary": "List posts in a workspace",
                "operationId": "postsIndex",
                "parameters": [
                    {
                        "name": "workspace_id",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Post list"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            },
            "post": {
                "tags": [
                    "Posts"
                ],
                "summary": "Create draft post",
                "operationId": "postsStore",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "workspace_id"
                                ],
                                "properties": {
                                    "workspace_id": {
                                        "type": "integer"
                                    },
                                    "title": {
                                        "type": "string",
                                        "nullable": true
                                    },
                                    "content": {
                                        "type": "string",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Created"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            }
        },
        "/posts/{post}": {
            "get": {
                "tags": [
                    "Posts"
                ],
                "summary": "Get post",
                "operationId": "postsShow",
                "parameters": [
                    {
                        "name": "post",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Post details"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            },
            "put": {
                "tags": [
                    "Posts"
                ],
                "summary": "Update post",
                "operationId": "postsUpdate",
                "parameters": [
                    {
                        "name": "post",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "nullable": true
                                    },
                                    "content": {
                                        "type": "string",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Updated"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Posts"
                ],
                "summary": "Delete post",
                "operationId": "postsDestroy",
                "parameters": [
                    {
                        "name": "post",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Deleted"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            }
        },
        "/posts/{post}/schedule": {
            "post": {
                "tags": [
                    "Posts"
                ],
                "summary": "Schedule post for publishing",
                "operationId": "postsSchedule",
                "parameters": [
                    {
                        "name": "post",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "scheduled_at"
                                ],
                                "properties": {
                                    "scheduled_at": {
                                        "type": "string",
                                        "format": "date-time"
                                    },
                                    "social_account_ids": {
                                        "type": "array",
                                        "items": {
                                            "type": "integer"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Scheduled"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            }
        },
        "/media/upload": {
            "post": {
                "tags": [
                    "Media"
                ],
                "summary": "Upload image or video",
                "operationId": "mediaUpload",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "workspace_id",
                                    "file"
                                ],
                                "properties": {
                                    "workspace_id": {
                                        "type": "integer"
                                    },
                                    "file": {
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Uploaded"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "servers": [
                    {
                        "url": "http://localhost:1981/klicklocal/backend/public/api/v1",
                        "description": "API v1 base URL"
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "ApiSuccessEnvelope": {
                "properties": {
                    "success": {
                        "type": "boolean",
                        "example": true
                    },
                    "message": {
                        "type": "string",
                        "example": "Success"
                    },
                    "data": {
                        "type": "object"
                    }
                },
                "type": "object"
            },
            "ApiErrorEnvelope": {
                "properties": {
                    "success": {
                        "type": "boolean",
                        "example": false
                    },
                    "message": {
                        "type": "string",
                        "example": "Validation failed."
                    },
                    "errors": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                },
                "type": "object"
            },
            "User": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "John Doe"
                    },
                    "email": {
                        "type": "string",
                        "format": "email"
                    },
                    "avatar": {
                        "type": "string",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "Workspace": {
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "owner_id": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string"
                    },
                    "slug": {
                        "type": "string"
                    },
                    "logo": {
                        "type": "string",
                        "nullable": true
                    },
                    "timezone": {
                        "type": "string",
                        "example": "UTC"
                    }
                },
                "type": "object"
            },
            "Post": {
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "workspace_id": {
                        "type": "integer"
                    },
                    "user_id": {
                        "type": "integer"
                    },
                    "title": {
                        "type": "string",
                        "nullable": true
                    },
                    "content": {
                        "type": "string",
                        "nullable": true
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "draft",
                            "scheduled",
                            "processing",
                            "published",
                            "failed"
                        ]
                    },
                    "scheduled_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "published_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Paste only the token from login/register (e.g. 18|abc...). Do not type \"Bearer\" — Swagger adds it automatically.",
                "bearerFormat": "Sanctum token",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Registration, login, and session"
        },
        {
            "name": "Workspaces",
            "description": "Workspace CRUD"
        },
        {
            "name": "Posts",
            "description": "Post CRUD and scheduling"
        },
        {
            "name": "Media",
            "description": "Media uploads"
        }
    ]
}