# Klicklocal backend (Laravel) - PRODUCTION on Hetzner Ubuntu
# Copy to the server as backend/.env and fill the secrets:
#   cp deploy/env/backend.env.production.example backend/.env
# Then:  php artisan key:generate

APP_NAME="Klicklocal"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.gastrocycle.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Local MySQL on the same Ubuntu server
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=klicklocal
DB_USERNAME=klicklocal
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# The browser talks to the Next.js proxy, so direct CORS is rarely hit,
# but keep these correct for any direct API calls.
SANCTUM_STATEFUL_DOMAINS=gastrocycle.com,www.gastrocycle.com,admin.gastrocycle.com
CORS_ALLOWED_ORIGINS=https://gastrocycle.com,https://www.gastrocycle.com,https://admin.gastrocycle.com

FRONTEND_URL=https://admin.gastrocycle.com

# Social providers: keep "fake" until the Meta app is live (see step 11)
SOCIAL_FACEBOOK_DRIVER=fake
SOCIAL_INSTAGRAM_DRIVER=fake
SOCIAL_LINKEDIN_DRIVER=fake

INSTAGRAM_ENABLED=false
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI="${APP_URL}/api/v1/social-accounts/instagram/callback"
INSTAGRAM_FRONTEND_REDIRECT="${FRONTEND_URL}/social-accounts"
INSTAGRAM_MEDIA_PUBLIC_BASE_URL="${APP_URL}/storage"
SOCIAL_FAKE_SUCCESS_RATE=0.85
SOCIAL_FAKE_MIN_DELAY_MS=1000
SOCIAL_FAKE_MAX_DELAY_MS=2000

L5_SWAGGER_CONST_HOST=https://api.gastrocycle.com/api/v1
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_UI_PERSIST_AUTHORIZATION=true

MAIL_MAILER=log

# Optional overrides for db:seed admin user
# PLATFORM_ADMIN_EMAIL=admin@klicklocal.test
# PLATFORM_ADMIN_PASSWORD=password
