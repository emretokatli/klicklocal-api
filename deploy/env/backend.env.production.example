# Klicklocal backend (Laravel) — PRODUCTION
# Domain: https://api.klicklocal.app   (deploys from `main` branch)
# Copy to the server as backend/.env and fill the secrets:
#   cp deploy/env/backend.env.production.example backend/.env
# Then:  php artisan key:generate
#
# RULES:
#   - Never use localhost URLs in production.
#   - All API endpoints come from environment variables.
#   - The production database MUST stay isolated from staging.

APP_NAME="Klicklocal"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.klicklocal.app

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_DE
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Production database — isolated, never shared with staging.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=klicklocal_prod
DB_USERNAME=klicklocal_prod
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Customer app + admin dashboard are the same Next.js app on two subdomains.
SANCTUM_STATEFUL_DOMAINS=klicklocal.app,www.klicklocal.app,admin.klicklocal.app
CORS_ALLOWED_ORIGINS=https://klicklocal.app,https://www.klicklocal.app,https://admin.klicklocal.app

# Where customers return after OAuth (customer dashboard host).
FRONTEND_URL=https://klicklocal.app

# AI content generation (OpenAI GPT-5)
OPENAI_DRIVER=api
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=60

# Social providers: keep "fake" until the Meta app is Live (see docs/META-APP-REVIEW.md)
SOCIAL_FACEBOOK_DRIVER=fake
SOCIAL_INSTAGRAM_DRIVER=fake
SOCIAL_LINKEDIN_DRIVER=fake

INSTAGRAM_ENABLED=false
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI="${APP_URL}/api/v1/social-accounts/instagram/callback"
INSTAGRAM_FRONTEND_REDIRECT="${FRONTEND_URL}/social-accounts"
INSTAGRAM_MEDIA_PUBLIC_BASE_URL="${APP_URL}/storage"

# TikTok Login Kit / Content Posting (use the production app credentials)
TIKTOK_ENABLED=false
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI="${APP_URL}/api/v1/social-accounts/tiktok/callback"
TIKTOK_FRONTEND_REDIRECT="${FRONTEND_URL}/social-accounts"

SOCIAL_FAKE_SUCCESS_RATE=0.85
SOCIAL_FAKE_MIN_DELAY_MS=1000
SOCIAL_FAKE_MAX_DELAY_MS=2000

L5_SWAGGER_CONST_HOST=https://api.klicklocal.app/api/v1
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_UI_PERSIST_AUTHORIZATION=true

MAIL_MAILER=log

# Optional overrides for db:seed admin user
# PLATFORM_ADMIN_EMAIL=admin@klicklocal.app
# PLATFORM_ADMIN_PASSWORD=CHANGE_ME
