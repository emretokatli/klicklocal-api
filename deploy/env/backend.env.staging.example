# Klicklocal backend (Laravel) — STAGING
# Domain: https://api-test.klicklocal.app   (deploys from `develop` branch)
# Copy to the staging server as backend/.env and fill the secrets:
#   cp deploy/env/backend.env.staging.example backend/.env
# Then:  php artisan key:generate
#
# RULES:
#   - Never use localhost URLs in deployed environments.
#   - All API endpoints come from environment variables.
#   - The staging database MUST stay isolated from production.

APP_NAME="Klicklocal (Staging)"
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://api-test.klicklocal.app

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_DE
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# Staging database — isolated, never shared with production.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=klicklocal_staging
DB_USERNAME=klicklocal_staging
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

SANCTUM_STATEFUL_DOMAINS=test.klicklocal.app,admin-test.klicklocal.app
CORS_ALLOWED_ORIGINS=https://test.klicklocal.app,https://admin-test.klicklocal.app

FRONTEND_URL=https://test.klicklocal.app

# AI content generation (OpenAI GPT-5) — use the fake driver on staging to save cost.
OPENAI_DRIVER=fake
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=60

SOCIAL_FACEBOOK_DRIVER=fake
SOCIAL_INSTAGRAM_DRIVER=fake
SOCIAL_LINKEDIN_DRIVER=fake

INSTAGRAM_ENABLED=false
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI="${APP_URL}/api/v1/social-accounts/instagram/callback"
INSTAGRAM_FRONTEND_REDIRECT="${FRONTEND_URL}/social-accounts"
INSTAGRAM_MEDIA_PUBLIC_BASE_URL="${APP_URL}/storage"
SOCIAL_FAKE_SUCCESS_RATE=0.85
SOCIAL_FAKE_MIN_DELAY_MS=1000
SOCIAL_FAKE_MAX_DELAY_MS=2000

L5_SWAGGER_CONST_HOST=https://api-test.klicklocal.app/api/v1
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_UI_PERSIST_AUTHORIZATION=true

MAIL_MAILER=log

# Optional overrides for db:seed admin user
# PLATFORM_ADMIN_EMAIL=admin@klicklocal.app
# PLATFORM_ADMIN_PASSWORD=CHANGE_ME
