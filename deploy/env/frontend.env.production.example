# Klicklocal frontend (Next.js) — PRODUCTION
# Customer app: https://klicklocal.app   Admin: https://admin.klicklocal.app
# API:          https://api.klicklocal.app   (deploys from `main` branch)
#
# Copy to the server as frontend/.env.local:
#   cp deploy/env/frontend.env.production.example frontend/.env.local
# Rebuild after any change:  npm run build  (then restart the service)
#
# Same-origin proxy mode (recommended): the browser only calls /api/v1 on the
# Next.js host, and Next.js forwards server-side to Laravel. No browser CORS.

NEXT_PUBLIC_API_URL=/api/v1
BACKEND_API_URL=https://api.klicklocal.app/api/v1
NEXT_PUBLIC_STORAGE_URL=https://api.klicklocal.app/storage

# Alternative (browser calls Laravel directly — needs CORS on backend):
# NEXT_PUBLIC_API_URL=https://api.klicklocal.app/api/v1
# NEXT_PUBLIC_STORAGE_URL=https://api.klicklocal.app/storage
