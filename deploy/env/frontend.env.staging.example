# Klicklocal frontend (Next.js) — STAGING
# Customer app: https://test.klicklocal.app   Admin: https://admin-test.klicklocal.app
# API:          https://api-test.klicklocal.app   (deploys from `develop` branch)
#
# Copy to the staging server as frontend/.env.local:
#   cp deploy/env/frontend.env.staging.example frontend/.env.local
# Rebuild after any change:  npm run build  (then restart the service)

NEXT_PUBLIC_API_URL=/api/v1
BACKEND_API_URL=https://api-test.klicklocal.app/api/v1
NEXT_PUBLIC_STORAGE_URL=https://api-test.klicklocal.app/storage

# Alternative (browser calls Laravel directly — needs CORS on backend):
# NEXT_PUBLIC_API_URL=https://api-test.klicklocal.app/api/v1
# NEXT_PUBLIC_STORAGE_URL=https://api-test.klicklocal.app/storage
